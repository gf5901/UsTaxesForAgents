{
  "name": "ustaxes",
  "version": "0.1.23",
  "private": true,
  "dependencies": {
    "ajv": "^8.18.0",
    "lodash": "^4.17.23",
    "loglevel": "^1.9.2",
    "pdf-lib": "^1.17.1",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "test": "ts-node ./scripts/env.ts && ts-node ./scripts/setup.ts && jest",
    "test:report": "ts-node ./scripts/env.ts && ts-node ./scripts/setup.ts && jest --coverage",
    "lint": "eslint ./src scripts --ext ts,js,tsx,jsx --max-warnings=0 && prettier -c .",
    "lint:fix": "eslint ./src scripts --fix --ext ts,js,tsx,jsx && prettier --write .",
    "prettier": "prettier --write .",
    "formgen": "ts-node ./scripts/formgen.ts",
    "cli": "ts-node -r tsconfig-paths/register scripts/run-cli.ts",
    "prepare": "ts-node ./scripts/env.ts && husky"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-promise": "^7.2.0",
    "fast-check": "^3.22.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^7.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown .",
    "src/**/*.{ts,js,tsx,jsx}": "eslint --cache --fix",
    "scripts/**/*.{ts,js,tsx,jsx}": "eslint --cache --fix"
  },
  "engines": {
    "yarn": "please-use-npm"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gf5901/UsTaxesForAgents.git"
  }
}
